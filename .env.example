# Copy to .env and fill in your own values.

# --- LLM (Groq) ---
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# --- Infrastructure (docker-compose.yml) ---
DATABASE_URL=postgresql+psycopg://finsight:finsight@localhost:5432/finsight
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=finsight_chunks
REDIS_URL=redis://localhost:6379/0

# --- Embedding (FastEmbed, ONNX CPU) ---
# Dense: multilingual e5-large (1024-dim, strong Vietnamese, cross-lingual).
FINSIGHT_EMBED_MODEL=intfloat/multilingual-e5-large
FINSIGHT_EMBED_DIM=1024

# --- Hybrid retrieval (dense + sparse BM25, fused with RRF) ---
# BM25 is the lexical layer that pins exact figures/codes/years; ~0 extra RAM.
FINSIGHT_USE_HYBRID=true
FINSIGHT_SPARSE_MODEL=Qdrant/bm25

# --- Rerank (OFF by default: heaviest CPU stage; hybrid + MMR replace it) ---
FINSIGHT_RERANK_MODEL=jinaai/jina-reranker-v2-base-multilingual
FINSIGHT_USE_RERANKER=false

# Auto-run PaddleOCR-VL inside the API for scanned PDFs (no text layer).
# false = reject scanned PDFs (OCR offline first); avoids loading a 3-5 GB VLM
# into the API process. Set true only on a machine with plenty of RAM/GPU.
FINSIGHT_ENABLE_API_OCR=false

# --- Retrieval ---
FINSIGHT_RETRIEVE_CANDIDATES=50   # candidates fetched before MMR trims to top_k
FINSIGHT_TOP_K=8                  # chunks fed to the LLM
FINSIGHT_MMR_LAMBDA=0.6           # 1.0 = pure relevance, 0.0 = pure diversity
FINSIGHT_SCORE_THRESHOLD=0.0      # >0 = strict grounding (may drop exact matches)
FINSIGHT_USE_ROUTING=true         # route question to its statement/note/year (soft, fallback)

# --- Chunking (character budgets) ---
FINSIGHT_CHUNK_SIZE=1800
FINSIGHT_CHUNK_OVERLAP=250

# --- Short-term memory (Redis) ---
FINSIGHT_MEMORY_WINDOW=6
FINSIGHT_MEMORY_TTL=86400

# --- Misc ---
FINSIGHT_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
FINSIGHT_MAX_UPLOAD_MB=50
